{
  "name": "ai-nft-forge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22.17.0",
    "pnpm": ">=10.11.1"
  },
  "scripts": {
    "app:up": "node scripts/run-app-up.mjs",
    "build": "turbo run build",
    "db:migrate:deploy": "pnpm --filter @ai-nft-forge/database prisma:migrate:deploy",
    "db:migrate:status": "pnpm --filter @ai-nft-forge/database prisma:migrate:status",
    "generation-backend:health": "pnpm --filter @ai-nft-forge/generation-backend health",
    "generation-backend:ready": "pnpm --filter @ai-nft-forge/generation-backend ready",
    "infra:config": "node scripts/run-compose.mjs local config",
    "infra:down": "node scripts/run-compose.mjs local down --remove-orphans",
    "infra:logs": "node scripts/run-compose.mjs local logs --tail=100",
    "infra:ps": "node scripts/run-compose.mjs local ps",
    "infra:selfhost:config": "node scripts/run-compose.mjs selfhost config",
    "infra:selfhost:down": "node scripts/run-compose.mjs selfhost down --remove-orphans",
    "infra:selfhost:logs": "node scripts/run-compose.mjs selfhost logs --tail=100",
    "infra:selfhost:ps": "node scripts/run-compose.mjs selfhost ps",
    "infra:selfhost:up": "node scripts/run-compose.mjs selfhost up -d --build",
    "infra:up": "node scripts/run-compose.mjs local up -d",
    "infra:up:gpu": "node scripts/run-compose.mjs local --with-gpu-compose up -d --profile gpu",
    "lint": "turbo run lint",
    "prisma:validate": "pnpm --filter @ai-nft-forge/database prisma:validate",
    "safe-push": "bash ./scripts/safe-push.sh",
    "setup:githooks": "git config --local core.hooksPath .githooks && chmod +x .githooks/pre-push scripts/verify-push.sh scripts/safe-push.sh",
    "test:smoke": "node scripts/run-browser-smoke.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify:push": "bash ./scripts/verify-push.sh",
    "worker:health": "pnpm --filter @ai-nft-forge/worker health",
    "format-check": "prettier --check .",
    "validate": "pnpm format-check && pnpm prisma:validate && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm worker:health && pnpm generation-backend:health"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
