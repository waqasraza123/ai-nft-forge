generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceStatus {
  active
  suspended
  archived
}

enum SourceAssetStatus {
  pending_upload
  uploaded
  upload_failed
}

enum GenerationRequestStatus {
  queued
  running
  succeeded
  failed
}

enum OpsQueueStatus {
  ok
  unreachable
}

enum OpsBackendReadinessStatus {
  ready
  not_ready
  unconfigured
  unreachable
}

enum OpsObservabilityStatus {
  ok
  warning
  critical
  unreachable
}

enum OpsAlertSeverity {
  warning
  critical
}

enum OpsAlertStateStatus {
  active
  resolved
}

enum OpsAlertDeliveryChannel {
  audit_log
  webhook
}

enum OpsAlertDeliveryState {
  delivered
  failed
}

enum CollectionDraftStatus {
  draft
  review_ready
}

model User {
  id                 String              @id @default(cuid()) @map("id")
  walletAddress      String              @unique @map("wallet_address")
  displayName        String?             @map("display_name")
  avatarUrl          String?             @map("avatar_url")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  authSessions       AuthSession[]
  collectionDrafts   CollectionDraft[]   @relation("CollectionDraftOwner")
  generatedAssets    GeneratedAsset[]    @relation("GeneratedAssetOwner")
  generationRequests GenerationRequest[] @relation("GenerationRequestOwner")
  publishedCollections PublishedCollection[] @relation("PublishedCollectionOwner")
  opsAlertDeliveries OpsAlertDelivery[]  @relation("OpsAlertDeliveryOwner")
  opsAlertMutes      OpsAlertMute[]      @relation("OpsAlertMuteOwner")
  opsAlertRoutingPolicies OpsAlertRoutingPolicy[] @relation("OpsAlertRoutingPolicyOwner")
  opsAlertEscalationPolicies OpsAlertEscalationPolicy[] @relation("OpsAlertEscalationPolicyOwner")
  opsAlertSchedulePolicies OpsAlertSchedulePolicy[] @relation("OpsAlertSchedulePolicyOwner")
  acknowledgedOpsAlertStates OpsAlertState[] @relation("OpsAlertStateAcknowledgedBy")
  opsAlertStates     OpsAlertState[]     @relation("OpsAlertStateOwner")
  opsCaptures        OpsObservabilityCapture[] @relation("OpsObservabilityCaptureOwner")
  opsWindowSnapshots OpsGenerationWindowSnapshot[] @relation("OpsGenerationWindowSnapshotOwner")
  ownedSourceAssets SourceAsset[] @relation("SourceAssetOwner")
  ownedWorkspaces    Workspace[]         @relation("WorkspaceOwner")

  @@map("users")
}

model AuthNonce {
  id            String   @id @default(cuid()) @map("id")
  walletAddress String   @map("wallet_address")
  nonce         String   @unique @map("nonce")
  expiresAt     DateTime @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([walletAddress, expiresAt], map: "auth_nonces_wallet_address_expires_at_idx")
  @@map("auth_nonces")
}

model AuthSession {
  id         String    @id @default(cuid()) @map("id")
  userId     String    @map("user_id")
  expiresAt  DateTime  @map("expires_at")
  userAgent  String?   @map("user_agent")
  ipHash     String?   @map("ip_hash")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model Workspace {
  id          String          @id @default(cuid()) @map("id")
  ownerUserId String          @map("owner_user_id")
  name        String          @map("name")
  slug        String          @unique @map("slug")
  status      WorkspaceStatus @default(active) @map("status")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  brands      Brand[]
  ownerUser   User            @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId], map: "workspaces_owner_user_id_idx")
  @@map("workspaces")
}

model Brand {
  id           String    @id @default(cuid()) @map("id")
  workspaceId  String    @map("workspace_id")
  name         String    @map("name")
  slug         String    @map("slug")
  themeJson    Json      @map("theme_json")
  customDomain String?   @map("custom_domain")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug], map: "brands_workspace_id_slug_key")
  @@index([workspaceId], map: "brands_workspace_id_idx")
  @@map("brands")
}

model AuditLog {
  id           String   @id @default(cuid()) @map("id")
  actorType    String   @map("actor_type")
  actorId      String   @map("actor_id")
  action       String   @map("action")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  metadataJson Json     @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorType, actorId], map: "audit_logs_actor_type_actor_id_idx")
  @@index([entityType, entityId], map: "audit_logs_entity_type_entity_id_idx")
  @@index([action], map: "audit_logs_action_idx")
  @@map("audit_logs")
}

model SourceAsset {
  id                 String              @id @default(cuid()) @map("id")
  ownerUserId        String              @map("owner_user_id")
  originalFilename   String              @map("original_filename")
  contentType        String              @map("content_type")
  storageBucket      String              @map("storage_bucket")
  storageObjectKey   String              @unique @map("storage_object_key")
  byteSize           Int?                @map("byte_size")
  status             SourceAssetStatus   @default(pending_upload) @map("status")
  uploadedAt         DateTime?           @map("uploaded_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  generatedAssets    GeneratedAsset[]
  generationRequests GenerationRequest[]
  ownerUser          User                @relation("SourceAssetOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status], map: "source_assets_owner_user_id_status_idx")
  @@map("source_assets")
}

model GenerationRequest {
  id                    String                  @id @default(cuid()) @map("id")
  sourceAssetId         String                  @map("source_asset_id")
  ownerUserId           String                  @map("owner_user_id")
  pipelineKey           String                  @map("pipeline_key")
  requestedVariantCount Int                     @map("requested_variant_count")
  status                GenerationRequestStatus @default(queued) @map("status")
  queueJobId            String?                 @map("queue_job_id")
  startedAt             DateTime?               @map("started_at")
  completedAt           DateTime?               @map("completed_at")
  failedAt              DateTime?               @map("failed_at")
  failureCode           String?                 @map("failure_code")
  failureMessage        String?                 @map("failure_message")
  resultJson            Json?                   @map("result_json")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  generatedAssets       GeneratedAsset[]
  ownerUser             User                    @relation("GenerationRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceAsset           SourceAsset             @relation(fields: [sourceAssetId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status], map: "generation_requests_owner_user_id_status_idx")
  @@index([sourceAssetId, createdAt], map: "generation_requests_source_asset_id_created_at_idx")
  @@index([queueJobId], map: "generation_requests_queue_job_id_idx")
  @@map("generation_requests")
}

model GeneratedAsset {
  id                  String            @id @default(cuid()) @map("id")
  generationRequestId String            @map("generation_request_id")
  sourceAssetId       String            @map("source_asset_id")
  ownerUserId         String            @map("owner_user_id")
  variantIndex        Int               @map("variant_index")
  contentType         String            @map("content_type")
  storageBucket       String            @map("storage_bucket")
  storageObjectKey    String            @unique @map("storage_object_key")
  byteSize            Int?              @map("byte_size")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  collectionDraftItems CollectionDraftItem[]
  publishedCollectionItems PublishedCollectionItem[]
  generationRequest   GenerationRequest @relation(fields: [generationRequestId], references: [id], onDelete: Cascade)
  ownerUser           User              @relation("GeneratedAssetOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceAsset         SourceAsset       @relation(fields: [sourceAssetId], references: [id], onDelete: Cascade)

  @@unique([generationRequestId, variantIndex], map: "generated_assets_generation_request_id_variant_index_key")
  @@index([ownerUserId, createdAt], map: "generated_assets_owner_user_id_created_at_idx")
  @@index([sourceAssetId, createdAt], map: "generated_assets_source_asset_id_created_at_idx")
  @@index([generationRequestId, createdAt], map: "generated_assets_generation_request_id_created_at_idx")
  @@map("generated_assets")
}

model CollectionDraft {
  id          String                @id @default(cuid()) @map("id")
  ownerUserId String                @map("owner_user_id")
  title       String                @map("title")
  slug        String                @map("slug")
  description String?               @map("description")
  status      CollectionDraftStatus @default(draft) @map("status")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  items       CollectionDraftItem[]
  publishedCollection PublishedCollection?
  ownerUser   User                  @relation("CollectionDraftOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, slug], map: "collection_drafts_owner_user_id_slug_key")
  @@index([ownerUserId, updatedAt], map: "collection_drafts_owner_user_id_updated_at_idx")
  @@map("collection_drafts")
}

model CollectionDraftItem {
  id                String          @id @default(cuid()) @map("id")
  collectionDraftId String          @map("collection_draft_id")
  generatedAssetId  String          @map("generated_asset_id")
  position          Int             @map("position")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  collectionDraft   CollectionDraft @relation(fields: [collectionDraftId], references: [id], onDelete: Cascade)
  generatedAsset    GeneratedAsset  @relation(fields: [generatedAssetId], references: [id], onDelete: Cascade)

  @@unique([collectionDraftId, generatedAssetId], map: "collection_draft_items_draft_asset_key")
  @@unique([collectionDraftId, position], map: "collection_draft_items_draft_position_key")
  @@index([generatedAssetId], map: "collection_draft_items_generated_asset_id_idx")
  @@map("collection_draft_items")
}

model PublishedCollection {
  id                    String                    @id @default(cuid()) @map("id")
  ownerUserId           String                    @map("owner_user_id")
  sourceCollectionDraftId String                  @unique @map("source_collection_draft_id")
  brandName             String                    @map("brand_name")
  brandSlug             String                    @map("brand_slug")
  isFeatured            Boolean                   @default(false) @map("is_featured")
  displayOrder          Int                       @default(0) @map("display_order")
  title                 String                    @map("title")
  slug                  String                    @map("slug")
  description           String?                   @map("description")
  publishedAt           DateTime                  @map("published_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  items                 PublishedCollectionItem[]
  ownerUser             User                      @relation("PublishedCollectionOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceCollectionDraft CollectionDraft           @relation(fields: [sourceCollectionDraftId], references: [id], onDelete: Cascade)

  @@unique([brandSlug, slug], map: "published_collections_brand_slug_slug_key")
  @@index([ownerUserId, updatedAt], map: "published_collections_owner_user_id_updated_at_idx")
  @@index([brandSlug, isFeatured, displayOrder, updatedAt], map: "published_collections_brand_featured_order_updated_at_idx")
  @@map("published_collections")
}

model PublishedCollectionItem {
  id                   String              @id @default(cuid()) @map("id")
  publishedCollectionId String             @map("published_collection_id")
  generatedAssetId     String              @map("generated_asset_id")
  position             Int                 @map("position")
  publicStorageBucket  String?             @map("public_storage_bucket")
  publicStorageObjectKey String?           @map("public_storage_object_key")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  generatedAsset       GeneratedAsset      @relation(fields: [generatedAssetId], references: [id], onDelete: Cascade)
  publishedCollection  PublishedCollection @relation(fields: [publishedCollectionId], references: [id], onDelete: Cascade)

  @@unique([publishedCollectionId, generatedAssetId], map: "pub_collection_items_pub_asset_key")
  @@unique([publishedCollectionId, position], map: "pub_collection_items_pub_position_key")
  @@unique([publicStorageObjectKey], map: "pub_collection_items_public_object_key")
  @@index([generatedAssetId], map: "published_collection_items_generated_asset_id_idx")
  @@map("published_collection_items")
}

model OpsObservabilityCapture {
  id                     String                   @id @default(cuid()) @map("id")
  ownerUserId            String                   @map("owner_user_id")
  capturedAt             DateTime                 @map("captured_at")
  queueStatus            OpsQueueStatus           @map("queue_status")
  queueWaitingCount      Int?                     @map("queue_waiting_count")
  queueActiveCount       Int?                     @map("queue_active_count")
  queueDelayedCount      Int?                     @map("queue_delayed_count")
  queueFailedCount       Int?                     @map("queue_failed_count")
  queueCompletedCount    Int?                     @map("queue_completed_count")
  queuePausedCount       Int?                     @map("queue_paused_count")
  queueConcurrency       Int?                     @map("queue_concurrency")
  workerAdapter          String?                  @map("worker_adapter")
  backendReadinessStatus OpsBackendReadinessStatus @map("backend_readiness_status")
  backendReadinessMessage String                  @map("backend_readiness_message")
  observabilityStatus    OpsObservabilityStatus   @map("observability_status")
  observabilityMessage   String                   @map("observability_message")
  oldestQueuedAgeSeconds Int?                     @map("oldest_queued_age_seconds")
  oldestRunningAgeSeconds Int?                    @map("oldest_running_age_seconds")
  criticalAlertCount     Int                      @default(0) @map("critical_alert_count")
  warningAlertCount      Int                      @default(0) @map("warning_alert_count")
  createdAt              DateTime                 @default(now()) @map("created_at")
  alertDeliveries        OpsAlertDelivery[]
  ownerUser              User                     @relation("OpsObservabilityCaptureOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  windowSnapshots        OpsGenerationWindowSnapshot[]

  @@index([ownerUserId, capturedAt], map: "ops_observability_captures_owner_user_id_captured_at_idx")
  @@map("ops_observability_captures")
}

model OpsGenerationWindowSnapshot {
  id                      String                  @id @default(cuid()) @map("id")
  captureId               String                  @map("capture_id")
  ownerUserId             String                  @map("owner_user_id")
  capturedAt              DateTime                @map("captured_at")
  windowKey               String                  @map("window_key")
  from                    DateTime                @map("from")
  label                   String                  @map("label")
  totalCount              Int                     @map("total_count")
  queuedCount             Int                     @map("queued_count")
  runningCount            Int                     @map("running_count")
  succeededCount          Int                     @map("succeeded_count")
  failedCount             Int                     @map("failed_count")
  storedAssetCount        Int                     @map("stored_asset_count")
  successRatePercent      Float?                  @map("success_rate_percent")
  averageCompletionSeconds Int?                   @map("average_completion_seconds")
  maxCompletionSeconds    Int?                    @map("max_completion_seconds")
  createdAt               DateTime                @default(now()) @map("created_at")
  capture                 OpsObservabilityCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  ownerUser               User                    @relation("OpsGenerationWindowSnapshotOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([captureId, windowKey], map: "ops_generation_window_snapshots_capture_id_window_key_key")
  @@index([ownerUserId, capturedAt], map: "ops_generation_window_snapshots_owner_user_id_captured_at_idx")
  @@map("ops_generation_window_snapshots")
}

model OpsAlertState {
  id                   String              @id @default(cuid()) @map("id")
  ownerUserId          String              @map("owner_user_id")
  acknowledgedByUserId String?             @map("acknowledged_by_user_id")
  code                 String              @map("code")
  severity             OpsAlertSeverity    @map("severity")
  title                String              @map("title")
  message              String              @map("message")
  status               OpsAlertStateStatus @default(active) @map("status")
  firstObservedAt      DateTime            @map("first_observed_at")
  lastObservedAt       DateTime            @map("last_observed_at")
  lastDeliveredAt      DateTime?           @map("last_delivered_at")
  lastAuditLogDeliveredAt DateTime?        @map("last_audit_log_delivered_at")
  firstWebhookDeliveredAt DateTime?        @map("first_webhook_delivered_at")
  lastWebhookDeliveredAt DateTime?         @map("last_webhook_delivered_at")
  acknowledgedAt       DateTime?           @map("acknowledged_at")
  resolvedAt           DateTime?           @map("resolved_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deliveries           OpsAlertDelivery[]
  acknowledgedByUser   User?               @relation("OpsAlertStateAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  ownerUser            User                @relation("OpsAlertStateOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, code], map: "ops_alert_states_owner_user_id_code_key")
  @@index([acknowledgedByUserId], map: "ops_alert_states_acknowledged_by_user_id_idx")
  @@index([ownerUserId, status], map: "ops_alert_states_owner_user_id_status_idx")
  @@map("ops_alert_states")
}

model OpsAlertMute {
  id          String   @id @default(cuid()) @map("id")
  ownerUserId String   @map("owner_user_id")
  code        String   @map("code")
  mutedUntil  DateTime @map("muted_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  ownerUser   User     @relation("OpsAlertMuteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, code], map: "ops_alert_mutes_owner_user_id_code_key")
  @@index([ownerUserId, mutedUntil], map: "ops_alert_mutes_owner_user_id_muted_until_idx")
  @@map("ops_alert_mutes")
}

model OpsAlertRoutingPolicy {
  id                     String           @id @default(cuid()) @map("id")
  ownerUserId            String           @map("owner_user_id")
  webhookEnabled         Boolean          @default(true) @map("webhook_enabled")
  webhookMinimumSeverity OpsAlertSeverity @default(warning) @map("webhook_minimum_severity")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  ownerUser              User             @relation("OpsAlertRoutingPolicyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId], map: "ops_alert_routing_policies_owner_user_id_key")
  @@map("ops_alert_routing_policies")
}

model OpsAlertSchedulePolicy {
  id               String   @id @default(cuid()) @map("id")
  ownerUserId      String   @map("owner_user_id")
  timezone         String   @map("timezone")
  activeDaysMask   Int      @map("active_days_mask")
  startMinuteOfDay Int      @map("start_minute_of_day")
  endMinuteOfDay   Int      @map("end_minute_of_day")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  ownerUser        User     @relation("OpsAlertSchedulePolicyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId], map: "ops_alert_schedule_policies_owner_user_id_key")
  @@map("ops_alert_schedule_policies")
}

model OpsAlertEscalationPolicy {
  id                            String   @id @default(cuid()) @map("id")
  ownerUserId                   String   @map("owner_user_id")
  firstReminderDelayMinutes     Int      @map("first_reminder_delay_minutes")
  repeatReminderIntervalMinutes Int      @map("repeat_reminder_interval_minutes")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")
  ownerUser                     User     @relation("OpsAlertEscalationPolicyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId], map: "ops_alert_escalation_policies_owner_user_id_key")
  @@map("ops_alert_escalation_policies")
}

model OpsAlertDelivery {
  id              String                  @id @default(cuid()) @map("id")
  captureId       String                  @map("capture_id")
  alertStateId    String                  @map("alert_state_id")
  ownerUserId     String                  @map("owner_user_id")
  code            String                  @map("code")
  severity        OpsAlertSeverity        @map("severity")
  title           String                  @map("title")
  message         String                  @map("message")
  deliveryChannel OpsAlertDeliveryChannel @map("delivery_channel")
  deliveryState   OpsAlertDeliveryState   @map("delivery_state")
  deliveredAt     DateTime?               @map("delivered_at")
  failureMessage  String?                 @map("failure_message")
  createdAt       DateTime                @default(now()) @map("created_at")
  alertState      OpsAlertState           @relation(fields: [alertStateId], references: [id], onDelete: Cascade)
  capture         OpsObservabilityCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  ownerUser       User                    @relation("OpsAlertDeliveryOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt], map: "ops_alert_deliveries_owner_user_id_created_at_idx")
  @@index([alertStateId, createdAt], map: "ops_alert_deliveries_alert_state_id_created_at_idx")
  @@map("ops_alert_deliveries")
}
