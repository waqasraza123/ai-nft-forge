generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceStatus {
  active
  suspended
  archived
}

enum WorkspaceMembershipRole {
  owner
  operator
  viewer
}

enum WorkspaceRoleEscalationRequestStatus {
  pending
  approved
  rejected
  canceled
}

enum WorkspaceDecommissionRequestStatus {
  scheduled
  canceled
  executed
}

enum WorkspaceDecommissionNotificationKind {
  scheduled
  upcoming
  ready
}

enum WorkspaceLifecycleNotificationDeliveryKind {
  invitation_reminder
  decommission_notice
}

enum WorkspaceLifecycleNotificationDeliveryChannel {
  audit_log
  webhook
}

enum WorkspaceLifecycleNotificationProviderKey {
  primary
  secondary
}

enum WorkspaceLifecycleNotificationDeliveryState {
  queued
  processing
  delivered
  failed
  skipped
}

enum WorkspaceLifecycleAutomationRunStatus {
  running
  succeeded
  failed
}

enum WorkspaceLifecycleAutomationRunTriggerSource {
  manual
  scheduled
}

enum SourceAssetStatus {
  pending_upload
  uploaded
  upload_failed
}

enum GenerationRequestStatus {
  queued
  running
  succeeded
  failed
}

enum GeneratedAssetModerationStatus {
  pending_review
  approved
  rejected
}

enum OpsQueueStatus {
  ok
  unreachable
}

enum OpsBackendReadinessStatus {
  ready
  not_ready
  unconfigured
  unreachable
}

enum OpsObservabilityStatus {
  ok
  warning
  critical
  unreachable
}

enum OpsAlertSeverity {
  warning
  critical
}

enum OpsAlertStateStatus {
  active
  resolved
}

enum OpsAlertDeliveryChannel {
  audit_log
  webhook
}

enum OpsAlertDeliveryState {
  delivered
  failed
}

enum OpsReconciliationRunStatus {
  succeeded
  failed
}

enum OpsReconciliationIssueStatus {
  open
  repaired
  ignored
}

enum OpsReconciliationIssueSeverity {
  warning
  critical
}

enum OpsReconciliationIssueKind {
  source_asset_object_missing
  generated_asset_object_missing
  published_public_asset_missing
  draft_contains_unapproved_asset
  review_ready_draft_invalid
  published_hero_asset_missing_from_snapshot
  published_contract_deployment_unverified
  published_contract_missing_onchain
  published_contract_owner_mismatch
  published_contract_metadata_mismatch
  published_token_mint_unverified
  published_token_owner_mismatch
}

enum CollectionDraftStatus {
  draft
  review_ready
}

enum PublishedCollectionStorefrontStatus {
  upcoming
  live
  sold_out
  ended
}

enum PublishedCollectionReservationStatus {
  pending
  completed
  expired
  canceled
}

enum CommerceCheckoutSessionStatus {
  open
  completed
  expired
  canceled
}

enum CommerceCheckoutFulfillmentStatus {
  unfulfilled
  fulfilled
}

enum CommerceFulfillmentProviderKind {
  manual
  webhook
}

enum CommerceFulfillmentAutomationStatus {
  idle
  queued
  processing
  submitted
  completed
  failed
}

enum CommerceCheckoutProviderKind {
  manual
  stripe
}

model User {
  id                                 String                           @id @default(cuid()) @map("id")
  walletAddress                      String                           @unique @map("wallet_address")
  displayName                        String?                          @map("display_name")
  avatarUrl                          String?                          @map("avatar_url")
  createdAt                          DateTime                         @default(now()) @map("created_at")
  updatedAt                          DateTime                         @updatedAt @map("updated_at")
  authSessions                       AuthSession[]
  collectionDrafts                   CollectionDraft[]                @relation("CollectionDraftOwner")
  generatedAssets                    GeneratedAsset[]                 @relation("GeneratedAssetOwner")
  generationRequests                 GenerationRequest[]              @relation("GenerationRequestOwner")
  publishedCollections               PublishedCollection[]            @relation("PublishedCollectionOwner")
  opsAlertDeliveries                 OpsAlertDelivery[]               @relation("OpsAlertDeliveryOwner")
  opsAlertMutes                      OpsAlertMute[]                   @relation("OpsAlertMuteOwner")
  opsAlertRoutingPolicies            OpsAlertRoutingPolicy[]          @relation("OpsAlertRoutingPolicyOwner")
  opsAlertEscalationPolicies         OpsAlertEscalationPolicy[]       @relation("OpsAlertEscalationPolicyOwner")
  opsAlertSchedulePolicies           OpsAlertSchedulePolicy[]         @relation("OpsAlertSchedulePolicyOwner")
  acknowledgedOpsAlertStates         OpsAlertState[]                  @relation("OpsAlertStateAcknowledgedBy")
  opsAlertStates                     OpsAlertState[]                  @relation("OpsAlertStateOwner")
  opsCaptures                        OpsObservabilityCapture[]        @relation("OpsObservabilityCaptureOwner")
  opsWindowSnapshots                 OpsGenerationWindowSnapshot[]    @relation("OpsGenerationWindowSnapshotOwner")
  opsReconciliationRuns              OpsReconciliationRun[]           @relation("OpsReconciliationRunOwner")
  opsReconciliationIssues            OpsReconciliationIssue[]         @relation("OpsReconciliationIssueOwner")
  publishedCollectionMints           PublishedCollectionMint[]        @relation("PublishedCollectionMintOwner")
  publishedCollectionReservations    PublishedCollectionReservation[] @relation("PublishedCollectionReservationOwner")
  commerceCheckoutSessions           CommerceCheckoutSession[]        @relation("CommerceCheckoutSessionOwner")
  ownedSourceAssets                  SourceAsset[]                    @relation("SourceAssetOwner")
  ownedWorkspaces                    Workspace[]                      @relation("WorkspaceOwner")
  workspaceMemberships               WorkspaceMembership[]
  workspaceDecommissionRequests      WorkspaceDecommissionRequest[] @relation("WorkspaceDecommissionRequestedBy")
  workspaceDecommissionCancellations WorkspaceDecommissionRequest[] @relation("WorkspaceDecommissionCanceledBy")
  workspaceDecommissionExecutions    WorkspaceDecommissionRequest[] @relation("WorkspaceDecommissionExecutedBy")
  workspaceDecommissionNotifications WorkspaceDecommissionNotification[]
  workspaceLifecycleNotificationDeliveries WorkspaceLifecycleNotificationDelivery[] @relation("WorkspaceLifecycleNotificationDeliveryOwner")
  workspaceInvitationsSent           WorkspaceInvitation[]            @relation("WorkspaceInvitationInvitedBy")
  workspaceRoleEscalationRequests    WorkspaceRoleEscalationRequest[] @relation("WorkspaceRoleEscalationRequestedBy")
  workspaceRoleEscalationTargets     WorkspaceRoleEscalationRequest[] @relation("WorkspaceRoleEscalationTarget")
  workspaceRoleEscalationResolutions WorkspaceRoleEscalationRequest[] @relation("WorkspaceRoleEscalationResolvedBy")

  @@map("users")
}

model AuthNonce {
  id            String    @id @default(cuid()) @map("id")
  walletAddress String    @map("wallet_address")
  nonce         String    @unique @map("nonce")
  expiresAt     DateTime  @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([walletAddress, expiresAt], map: "auth_nonces_wallet_address_expires_at_idx")
  @@map("auth_nonces")
}

model AuthSession {
  id        String    @id @default(cuid()) @map("id")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  userAgent String?   @map("user_agent")
  ipHash    String?   @map("ip_hash")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model Workspace {
  id                     String                           @id @default(cuid()) @map("id")
  ownerUserId            String                           @map("owner_user_id")
  name                   String                           @map("name")
  slug                   String                           @unique @map("slug")
  status                 WorkspaceStatus                  @default(active) @map("status")
  decommissionRetentionDaysDefault Int                    @default(30) @map("decommission_retention_days_default")
  decommissionRetentionDaysMinimum Int                    @default(7) @map("decommission_retention_days_minimum")
  requireDecommissionReason Boolean                       @default(false) @map("require_decommission_reason")
  lifecycleAutomationEnabled Boolean                      @default(true) @map("lifecycle_automation_enabled")
  lifecycleAutomationInvitationRemindersEnabled Boolean   @default(true) @map("lifecycle_automation_invitation_reminders_enabled")
  lifecycleAutomationDecommissionNoticesEnabled Boolean   @default(true) @map("lifecycle_automation_decommission_notices_enabled")
  lifecycleSlaEnabled      Boolean                        @default(true) @map("lifecycle_sla_enabled")
  lifecycleSlaWebhookFailureThreshold Int                 @default(3) @map("lifecycle_sla_webhook_failure_threshold")
  lifecycleSlaAutomationMaxAgeMinutes Int                 @default(180) @map("lifecycle_sla_automation_max_age_minutes")
  lifecycleWebhookEnabled Boolean                         @default(false) @map("lifecycle_webhook_enabled")
  lifecycleWebhookDeliverInvitationReminders Boolean      @default(true) @map("lifecycle_webhook_deliver_invitation_reminders")
  lifecycleWebhookDeliverDecommissionNotifications Boolean @default(true) @map("lifecycle_webhook_deliver_decommission_notifications")
  createdAt              DateTime                         @default(now()) @map("created_at")
  updatedAt              DateTime                         @updatedAt @map("updated_at")
  brands                 Brand[]
  collectionDrafts       CollectionDraft[]
  decommissionRequests   WorkspaceDecommissionRequest[]
  generatedAssets        GeneratedAsset[]
  generationRequests     GenerationRequest[]
  invitations            WorkspaceInvitation[]
  lifecycleNotificationDeliveries WorkspaceLifecycleNotificationDelivery[]
  memberships            WorkspaceMembership[]
  opsAlertDeliveries     OpsAlertDelivery[]
  opsAlertEscalationPolicies OpsAlertEscalationPolicy[]
  opsAlertMutes          OpsAlertMute[]
  opsAlertRoutingPolicies OpsAlertRoutingPolicy[]
  opsAlertSchedulePolicies OpsAlertSchedulePolicy[]
  opsAlertStates         OpsAlertState[]
  opsGenerationWindowSnapshots OpsGenerationWindowSnapshot[]
  opsObservabilityCaptures OpsObservabilityCapture[]
  opsReconciliationIssues OpsReconciliationIssue[]
  opsReconciliationRuns  OpsReconciliationRun[]
  publishedCollections   PublishedCollection[]
  roleEscalationRequests WorkspaceRoleEscalationRequest[]
  sourceAssets           SourceAsset[]
  ownerUser              User                             @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId], map: "workspaces_owner_user_id_idx")
  @@map("workspaces")
}

model WorkspaceDecommissionRequest {
  id                String                            @id @default(cuid()) @map("id")
  workspaceId       String                            @map("workspace_id")
  requestedByUserId String                            @map("requested_by_user_id")
  retentionDays     Int                               @map("retention_days")
  exportConfirmedAt DateTime                          @map("export_confirmed_at")
  executeAfter      DateTime                          @map("execute_after")
  reason            String?                           @map("reason")
  status            WorkspaceDecommissionRequestStatus @default(scheduled) @map("status")
  canceledByUserId  String?                           @map("canceled_by_user_id")
  canceledAt        DateTime?                         @map("canceled_at")
  executedByUserId  String?                           @map("executed_by_user_id")
  executedAt        DateTime?                         @map("executed_at")
  createdAt         DateTime                          @default(now()) @map("created_at")
  updatedAt         DateTime                          @updatedAt @map("updated_at")
  canceledByUser    User?                             @relation("WorkspaceDecommissionCanceledBy", fields: [canceledByUserId], references: [id], onDelete: SetNull)
  executedByUser    User?                             @relation("WorkspaceDecommissionExecutedBy", fields: [executedByUserId], references: [id], onDelete: SetNull)
  notifications     WorkspaceDecommissionNotification[]
  requestedByUser   User                              @relation("WorkspaceDecommissionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  workspace         Workspace                         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, executeAfter], map: "workspace_decommission_requests_ws_status_execute_idx")
  @@index([requestedByUserId, status], map: "workspace_decommission_requests_requested_status_idx")
  @@map("workspace_decommission_requests")
}

model WorkspaceDecommissionNotification {
  id           String                               @id @default(cuid()) @map("id")
  requestId    String                               @map("request_id")
  kind         WorkspaceDecommissionNotificationKind @map("kind")
  sentByUserId String                               @map("sent_by_user_id")
  sentAt       DateTime                             @default(now()) @map("sent_at")
  createdAt    DateTime                             @default(now()) @map("created_at")
  deliveries   WorkspaceLifecycleNotificationDelivery[]
  request      WorkspaceDecommissionRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sentByUser   User                                 @relation(fields: [sentByUserId], references: [id], onDelete: Cascade)

  @@unique([requestId, kind], map: "workspace_decommission_notifications_request_kind_key")
  @@index([requestId, sentAt], map: "workspace_decommission_notifications_request_sent_at_idx")
  @@index([sentByUserId, sentAt], map: "workspace_decommission_notifications_sent_by_sent_at_idx")
  @@map("workspace_decommission_notifications")
}

model WorkspaceMembership {
  id          String                  @id @default(cuid()) @map("id")
  workspaceId String                  @map("workspace_id")
  userId      String                  @map("user_id")
  role        WorkspaceMembershipRole @default(operator) @map("role")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId], map: "workspace_memberships_workspace_id_user_id_key")
  @@index([workspaceId], map: "workspace_memberships_workspace_id_idx")
  @@index([userId], map: "workspace_memberships_user_id_idx")
  @@map("workspace_memberships")
}

model WorkspaceInvitation {
  id              String                  @id @default(cuid()) @map("id")
  workspaceId     String                  @map("workspace_id")
  invitedByUserId String                  @map("invited_by_user_id")
  walletAddress   String                  @map("wallet_address")
  role            WorkspaceMembershipRole @default(operator) @map("role")
  expiresAt       DateTime                @map("expires_at")
  lastRemindedAt  DateTime?               @map("last_reminded_at")
  reminderCount   Int                     @default(0) @map("reminder_count")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  lifecycleNotificationDeliveries WorkspaceLifecycleNotificationDelivery[]
  invitedByUser   User                    @relation("WorkspaceInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  workspace       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, walletAddress], map: "workspace_invitations_workspace_id_wallet_address_key")
  @@index([walletAddress], map: "workspace_invitations_wallet_address_idx")
  @@index([workspaceId], map: "workspace_invitations_workspace_id_idx")
  @@index([expiresAt], map: "workspace_invitations_expires_at_idx")
  @@map("workspace_invitations")
}

model WorkspaceLifecycleNotificationDelivery {
  id                        String                                       @id @default(cuid()) @map("id")
  workspaceId               String                                       @map("workspace_id")
  ownerUserId               String                                       @map("owner_user_id")
  invitationId              String?                                      @map("invitation_id")
  decommissionNotificationId String?                                     @map("decommission_notification_id")
  eventKind                 WorkspaceLifecycleNotificationDeliveryKind    @map("event_kind")
  deliveryChannel           WorkspaceLifecycleNotificationDeliveryChannel @default(webhook) @map("delivery_channel")
  providerKey               WorkspaceLifecycleNotificationProviderKey?    @map("provider_key")
  deliveryState             WorkspaceLifecycleNotificationDeliveryState   @map("delivery_state")
  eventOccurredAt           DateTime                                     @map("event_occurred_at")
  payloadJson               Json                                         @map("payload_json")
  attemptCount              Int                                          @default(0) @map("attempt_count")
  queuedAt                  DateTime?                                    @map("queued_at")
  lastAttemptedAt           DateTime?                                    @map("last_attempted_at")
  deliveredAt               DateTime?                                    @map("delivered_at")
  failedAt                  DateTime?                                    @map("failed_at")
  failureMessage            String?                                      @map("failure_message")
  createdAt                 DateTime                                     @default(now()) @map("created_at")
  updatedAt                 DateTime                                     @updatedAt @map("updated_at")
  decommissionNotification  WorkspaceDecommissionNotification?           @relation(fields: [decommissionNotificationId], references: [id], onDelete: Cascade)
  invitation                WorkspaceInvitation?                         @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  ownerUser                 User                                         @relation("WorkspaceLifecycleNotificationDeliveryOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  workspace                 Workspace                                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([decommissionNotificationId, deliveryChannel, providerKey], map: "ws_lifecycle_deliveries_notification_channel_provider_key")
  @@index([workspaceId, createdAt], map: "ws_lifecycle_deliveries_workspace_created_at_idx")
  @@index([workspaceId, deliveryChannel, providerKey, createdAt], map: "ws_lifecycle_deliveries_ws_chan_provider_created_idx")
  @@index([workspaceId, deliveryState, createdAt], map: "ws_lifecycle_deliveries_workspace_state_created_at_idx")
  @@index([ownerUserId, createdAt], map: "ws_lifecycle_deliveries_owner_created_at_idx")
  @@index([eventKind, deliveryState, createdAt], map: "ws_lifecycle_deliveries_kind_state_created_at_idx")
  @@map("workspace_lifecycle_notification_deliveries")
}

model WorkspaceLifecycleAutomationRun {
  id                      String                                    @id @default(cuid()) @map("id")
  triggerSource           WorkspaceLifecycleAutomationRunTriggerSource @map("trigger_source")
  status                  WorkspaceLifecycleAutomationRunStatus     @default(running) @map("status")
  workspaceCount          Int                                       @default(0) @map("workspace_count")
  invitationReminderCount Int                                       @default(0) @map("invitation_reminder_count")
  decommissionNoticeCount Int                                       @default(0) @map("decommission_notice_count")
  auditLogDeliveryCount   Int                                       @default(0) @map("audit_log_delivery_count")
  webhookQueuedCount      Int                                       @default(0) @map("webhook_queued_count")
  failedWorkspaceCount    Int                                       @default(0) @map("failed_workspace_count")
  failureMessage          String?                                   @map("failure_message")
  startedAt               DateTime                                  @map("started_at")
  completedAt             DateTime?                                 @map("completed_at")
  createdAt               DateTime                                  @default(now()) @map("created_at")
  updatedAt               DateTime                                  @updatedAt @map("updated_at")

  @@index([createdAt], map: "ws_lifecycle_automation_runs_created_at_idx")
  @@index([status, createdAt], map: "ws_lifecycle_automation_runs_status_created_at_idx")
  @@map("workspace_lifecycle_automation_runs")
}

model WorkspaceRoleEscalationRequest {
  id                String                               @id @default(cuid()) @map("id")
  workspaceId       String                               @map("workspace_id")
  requestedByUserId String                               @map("requested_by_user_id")
  targetUserId      String                               @map("target_user_id")
  requestedRole     WorkspaceMembershipRole              @default(owner) @map("requested_role")
  justification     String?                              @map("justification")
  status            WorkspaceRoleEscalationRequestStatus @default(pending) @map("status")
  resolvedByUserId  String?                              @map("resolved_by_user_id")
  resolvedAt        DateTime?                            @map("resolved_at")
  createdAt         DateTime                             @default(now()) @map("created_at")
  updatedAt         DateTime                             @updatedAt @map("updated_at")
  requestedByUser   User                                 @relation("WorkspaceRoleEscalationRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  resolvedByUser    User?                                @relation("WorkspaceRoleEscalationResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  targetUser        User                                 @relation("WorkspaceRoleEscalationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  workspace         Workspace                            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt], map: "workspace_role_escalation_requests_ws_status_created_idx")
  @@index([requestedByUserId, status], map: "workspace_role_escalation_requests_requested_status_idx")
  @@index([targetUserId, status], map: "workspace_role_escalation_requests_target_status_idx")
  @@map("workspace_role_escalation_requests")
}

model Brand {
  id           String    @id @default(cuid()) @map("id")
  workspaceId  String    @map("workspace_id")
  name         String    @map("name")
  slug         String    @map("slug")
  themeJson    Json      @map("theme_json")
  customDomain String?   @map("custom_domain")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug], map: "brands_workspace_id_slug_key")
  @@index([workspaceId], map: "brands_workspace_id_idx")
  @@map("brands")
}

model AuditLog {
  id           String   @id @default(cuid()) @map("id")
  actorType    String   @map("actor_type")
  actorId      String   @map("actor_id")
  action       String   @map("action")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  metadataJson Json     @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorType, actorId], map: "audit_logs_actor_type_actor_id_idx")
  @@index([entityType, entityId], map: "audit_logs_entity_type_entity_id_idx")
  @@index([entityType, entityId, createdAt], map: "audit_logs_entity_type_entity_id_created_at_idx")
  @@index([action], map: "audit_logs_action_idx")
  @@map("audit_logs")
}

model SourceAsset {
  id                 String              @id @default(cuid()) @map("id")
  workspaceId        String              @map("workspace_id")
  ownerUserId        String              @map("owner_user_id")
  originalFilename   String              @map("original_filename")
  contentType        String              @map("content_type")
  storageBucket      String              @map("storage_bucket")
  storageObjectKey   String              @unique @map("storage_object_key")
  byteSize           Int?                @map("byte_size")
  status             SourceAssetStatus   @default(pending_upload) @map("status")
  uploadedAt         DateTime?           @map("uploaded_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  generatedAssets    GeneratedAsset[]
  generationRequests GenerationRequest[]
  ownerUser          User                @relation("SourceAssetOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status], map: "source_assets_workspace_id_status_idx")
  @@index([ownerUserId, status], map: "source_assets_owner_user_id_status_idx")
  @@map("source_assets")
}

model GenerationRequest {
  id                    String                  @id @default(cuid()) @map("id")
  sourceAssetId         String                  @map("source_asset_id")
  workspaceId           String                  @map("workspace_id")
  ownerUserId           String                  @map("owner_user_id")
  pipelineKey           String                  @map("pipeline_key")
  requestedVariantCount Int                     @map("requested_variant_count")
  status                GenerationRequestStatus @default(queued) @map("status")
  queueJobId            String?                 @map("queue_job_id")
  startedAt             DateTime?               @map("started_at")
  completedAt           DateTime?               @map("completed_at")
  failedAt              DateTime?               @map("failed_at")
  failureCode           String?                 @map("failure_code")
  failureMessage        String?                 @map("failure_message")
  resultJson            Json?                   @map("result_json")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  generatedAssets       GeneratedAsset[]
  ownerUser             User                    @relation("GenerationRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceAsset           SourceAsset             @relation(fields: [sourceAssetId], references: [id], onDelete: Cascade)
  workspace             Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status], map: "generation_requests_workspace_id_status_idx")
  @@index([ownerUserId, status], map: "generation_requests_owner_user_id_status_idx")
  @@index([sourceAssetId, createdAt], map: "generation_requests_source_asset_id_created_at_idx")
  @@index([queueJobId], map: "generation_requests_queue_job_id_idx")
  @@map("generation_requests")
}

model GeneratedAsset {
  id                                 String                         @id @default(cuid()) @map("id")
  generationRequestId                String                         @map("generation_request_id")
  sourceAssetId                      String                         @map("source_asset_id")
  workspaceId                        String                         @map("workspace_id")
  ownerUserId                        String                         @map("owner_user_id")
  variantIndex                       Int                            @map("variant_index")
  contentType                        String                         @map("content_type")
  storageBucket                      String                         @map("storage_bucket")
  storageObjectKey                   String                         @unique @map("storage_object_key")
  byteSize                           Int?                           @map("byte_size")
  moderationStatus                   GeneratedAssetModerationStatus @default(pending_review) @map("moderation_status")
  moderatedAt                        DateTime?                      @map("moderated_at")
  createdAt                          DateTime                       @default(now()) @map("created_at")
  updatedAt                          DateTime                       @updatedAt @map("updated_at")
  collectionDraftItems               CollectionDraftItem[]
  storefrontHeroPublishedCollections PublishedCollection[]          @relation("PublishedCollectionHeroGeneratedAsset")
  publishedCollectionItems           PublishedCollectionItem[]
